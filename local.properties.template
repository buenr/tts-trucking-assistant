# Template for local.properties
# Copy this file to local.properties and fill in your actual values
# DO NOT commit local.properties to version control - it contains secrets!

# Required: Google Cloud Project ID for Vertex AI
# Get this from your Google Cloud Console: https://console.cloud.google.com/
VERTEX_AI_PROJECT_ID=your-project-id-here

# Optional: Vertex AI Location (default: global)
# Options: global, us-central1, us-east1, europe-west1, asia-northeast1, etc.
VERTEX_AI_LOCATION=global

# Optional: Gemini Model name (default: gemini-2.5-flash)
# Options: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash, etc.
VERTEX_AI_MODEL=gemini-2.5-flash

# Alternative Authentication Methods (choose one):

# Method 1: Application Default Credentials (ADC) - RECOMMENDED for development
# Set the GOOGLE_APPLICATION_CREDENTIALS environment variable to point to your service account JSON:
# export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Method 2: Service account JSON in assets (fallback)
# Place your service account JSON file at:
# app/src/main/assets/vertex-ai-testing1.json

# Method 3: Embed service account JSON (not recommended for production)
# VERTEX_AI_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
